---
import Button from '../ui/Button.astro';
import logoBookmark from '../../assets/images/logo-bookmark.svg';
import logoBookmarkDark from "../../assets/images/logo-bookmark-dark.svg"
import iconHamburger from '../../assets/images/icon-hamburger.svg';
import iconClose from '../../assets/images/icon-close.svg';
import iconFacebook from '../../assets/images/icon-facebook.svg';
import iconTwitter from '../../assets/images/icon-twitter.svg';
---

<header class="site-header ">
  <div class="container" >
  <a class="brand-link" href="#" aria-label="Bookmark home">
    <img src={logoBookmark.src} alt="Bookmark" width="148" height="25" />
  </a>

  <nav class="desktop-nav" aria-label="Main navigation">
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="#contact">Contact</a>
    <Button type="button" variant="login">Login</Button>
  </nav>

  <button
    class="menu-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label="Open menu"
    data-menu-toggle
  >
    <img src={iconHamburger.src} alt="" width="18" height="15" />
  </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
  <div class="mobile-menu-head container">
    <img src={logoBookmarkDark.src} class="mobile-logo" alt="Bookmark" width="148" height="25" />
    <button class="menu-close" type="button" aria-label="Close menu" data-menu-close>
      <img src={iconClose.src} alt="" width="16" height="15" />
    </button>
  </div>
  <nav class="mobile-nav container" aria-label="Mobile navigation">
    <a href="#features" data-mobile-menu-link>Features</a>
    <a href="#pricing" data-mobile-menu-link>Pricing</a>
    <a href="#contact" data-mobile-menu-link>Contact</a>
    <Button type="button" variant="menu-login">Login</Button>
  </nav>
  <div class="mobile-socials">
    <a href="#" aria-label="Visit our Facebook page">
      <img src={iconFacebook.src} alt="" width="24" height="24" />
    </a>
    <a href="#" aria-label="Visit our Twitter page">
      <img src={iconTwitter.src} alt="" width="24" height="20" />
    </a>
  </div>
</div>

<script>
  const initMobileMenu = () => {
  const menuToggle =
    document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menuClose =
    document.querySelector<HTMLButtonElement>("[data-menu-close]");
  const mobileMenu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const mobileMenuLinks = document.querySelectorAll<HTMLAnchorElement>(
    "[data-mobile-menu-link]",
  );

  if (!menuToggle || !menuClose || !mobileMenu) return;

  const openMenu = () => {
    mobileMenu.hidden = false;
    menuToggle.setAttribute("aria-expanded", "true");
    document.body.classList.add("menu-open");
  };

  const closeMenu = () => {
    mobileMenu.hidden = true;
    menuToggle.setAttribute("aria-expanded", "false");
    document.body.classList.remove("menu-open");
  };

  menuToggle.addEventListener("click", openMenu);
  menuClose.addEventListener("click", closeMenu);
  mobileMenuLinks.forEach((link) => link.addEventListener("click", closeMenu));
};

const initLandingPage = () => {
  initMobileMenu();
};

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initLandingPage, {
    once: true,
  });
} else {
  initLandingPage();
}
</script>

<style is:global>
.site-header {
  position: sticky;
  top: 0;
  background-color: #fff;
  z-index: 30;
}

.site-header .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 2.5rem;
  padding-bottom: 2.5rem;
}

.brand-link {
  flex-shrink: 0;
}

.desktop-nav {
  display: none;
  align-items: center;
  gap: 2.8rem;
  text-transform: uppercase;
  font-size: 0.81rem;
  letter-spacing: 0.11em;
  color: var(--blue-950);
}

.desktop-nav a:hover,
.desktop-nav a:focus-visible {
  color: var(--red-400);
  outline: 0;
}

.menu-toggle,
.menu-close {
  background: transparent;
  border: 0;
  cursor: pointer;
  padding: 0;
  line-height: 0;
}

.mobile-menu {
  position: fixed;
  inset: 0;
  background: hsl(229 31% 21% / 0.95);
  z-index: 40;
  display: flex;
  flex-direction: column;
  padding-top: 2.7rem;
  padding-bottom: 3rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 1.25rem;
}

.mobile-menu-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 2.3rem;
}

.mobile-nav {
  display: flex;
  flex-direction: column;
  text-align: center;
  border-top: 1px solid hsl(0 0% 100% / 0.25);
  border-bottom: 1px solid hsl(0 0% 100% / 0.25);
}

.mobile-nav a,
.btn-menu-login {
  padding-block: 1.3rem;
  color: #fff;
  border-bottom: 1px solid hsl(0 0% 100% / 0.25);
}

.mobile-nav a:last-of-type {
  border-bottom: 0;
}

.btn-menu-login {
  background: transparent;
  border: 2px solid #fff;
  margin: 1.5rem 0;
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border-radius: 0.35rem;
  font-weight: 500;
}

.mobile-socials {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  margin-top: auto;
  padding-top: 2rem;
}

.mobile-socials a:hover img,
.mobile-socials a:focus-visible img {
  filter: brightness(0) saturate(100%) invert(49%) sepia(89%) saturate(1244%)
    hue-rotate(322deg) hue-rotate(0deg);
  outline: 0;
}

@media (min-width: 48em) {
  .site-header .container {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .menu-toggle,
  .mobile-menu {
    display: none;
  }

  .desktop-nav {
    display: flex;
  }
}
</style>